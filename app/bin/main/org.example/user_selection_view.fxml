<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" stylesheets="@styles.css" alignment="CENTER"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controller.UserSelectionController"
      style="-fx-padding: 30;">
    
    <Label text="Select Your Account" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
    
    <Label text="Choose the user account you want to log in as:" 
           style="-fx-font-size: 14px; -fx-text-fill: #666666;" />
    
    <ListView fx:id="userListView" prefHeight="250.0" VBox.vgrow="ALWAYS" />
    
    <Label text="Preferred language:" style="-fx-font-size: 14px; -fx-text-fill: #666666;" />
    <ComboBox fx:id="langCombo" prefWidth="220.0" />
    
    <HBox spacing="10.0" alignment="CENTER">
        <Button fx:id="selectButton" text="Continue" prefWidth="150.0" 
                onAction="#onSelectClicked" styleClass="accent-button" />
    </HBox>
</VBox>
