<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controller.ReportsController" style="-fx-padding: 16;">
    <Label text="My Reports" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
    <ListView fx:id="reportsListView" VBox.vgrow="ALWAYS" />
    <HBox spacing="10">
        <Button text="Edit" onAction="#onEditClicked" />
        <Button text="Delete" onAction="#onDeleteClicked" style="-fx-text-fill: #cc0000;" />
        <Button text="Close" onAction="#onCloseClicked" />
    </HBox>
</VBox>
