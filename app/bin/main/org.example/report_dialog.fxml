<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox spacing="12.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controller.ReportDialogController" style="-fx-padding: 16;">
    <Label fx:id="titleLabel" text="Report User" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
    <Label fx:id="subtitleLabel" text="Please provide a reason for reporting this user." />
    <TextArea fx:id="reasonArea" prefRowCount="6" wrapText="true" />
    <HBox spacing="10">
        <Button text="Submit" onAction="#onSubmitClicked" styleClass="accent-button" />
        <Button text="Cancel" onAction="#onCancelClicked" />
    </HBox>
</VBox>
