<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<HBox spacing="15.0" stylesheets="@styles.css" 
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controller.ConversationsController"
      style="-fx-padding: 20;">
    
    <VBox spacing="12.0" prefWidth="450.0">
        <Label text="My Conversations" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
        <ListView fx:id="conversationListView" VBox.vgrow="ALWAYS" />
        
        <HBox spacing="8.0">
            <Button text="New Chat" onAction="#onNewConversationClicked" HBox.hgrow="ALWAYS" prefWidth="140.0" styleClass="accent-button" />
            <Button text="Report User" onAction="#onReportUserClicked" HBox.hgrow="ALWAYS" prefWidth="140.0" />
            <Button text="My Reports" onAction="#onMyReportsClicked" HBox.hgrow="ALWAYS" prefWidth="140.0" />
            <Button text="Logout" onAction="#onLogoutClicked" prefWidth="80.0" />
        </HBox>
    </VBox>

    <VBox spacing="15.0" HBox.hgrow="ALWAYS">
        <HBox spacing="10.0" style="-fx-border-color: #cccccc; -fx-border-width: 0 0 1 0; -fx-padding: 0 0 10 0;">
            <Label fx:id="conversationTitleLabel" text="Select a conversation" 
                   style="-fx-font-size: 16px; -fx-font-weight: bold;" HBox.hgrow="ALWAYS" />
            <Button fx:id="deleteConvButton" text="🗑 Delete" onAction="#onDeleteConversationClicked" 
                    style="-fx-text-fill: #cc0000;" visible="false" />
        </HBox>

        <ListView fx:id="messageListView" VBox.vgrow="ALWAYS" />

        <HBox spacing="10.0" alignment="CENTER">
            <TextField fx:id="inputField" HBox.hgrow="ALWAYS" promptText="Type a message..." />
            <Button text="Send" onAction="#onSendClicked" styleClass="accent-button" />
        </HBox>
    </VBox>
</HBox>
