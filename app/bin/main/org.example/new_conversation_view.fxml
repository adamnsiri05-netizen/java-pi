<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox spacing="15.0" stylesheets="@styles.css"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controller.NewConversationController"
      style="-fx-padding: 20;">
    
    <Label text="Start New Conversation" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
    
    <Label text="Select a user you haven't chatted with yet:" 
           style="-fx-font-size: 12px; -fx-text-fill: #666666;" />
    
    <ListView fx:id="availableUsersListView" prefHeight="250.0" VBox.vgrow="ALWAYS" />
    
    <HBox spacing="10.0" alignment="CENTER">
        <Button text="Start Chat" onAction="#onStartChatClicked" prefWidth="120.0" 
                styleClass="accent-button" />
        <Button text="Cancel" onAction="#onCancelClicked" prefWidth="120.0" />
    </HBox>
</VBox>
